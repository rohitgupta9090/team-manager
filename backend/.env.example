# --- SQLite (simple local dev; default when DATABASE_URL is unset) ---
# Optional explicit flag:
# USE_SQLITE=1
# Database file: backend/db.sqlite3 (run: python manage.py migrate)

# --- Postgres (recommended for Railway / production) ---
# Railway: add the Postgres plugin → DATABASE_URL is injected automatically.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Deploy ---
# DJANGO_DEBUG=0
# SECRET_KEY=generate-a-long-random-string
# ALLOWED_HOSTS=your-app.up.railway.app
